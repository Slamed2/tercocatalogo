# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_VECTOR_STORE_ID=vs_...

# Server
PORT=3000

# URL pública del deploy (ej. https://eventos.tu-easypanel.host)
# Cuando está seteada, los links MAPA_DE "X" → /mapas/foo.png se reescriben a
# absolutos ({PUBLIC_BASE_URL}/mapas/foo.png) al subir al vector store de OpenAI.
PUBLIC_BASE_URL=

# Auth básica para proteger el editor
AUTH_USER=admin
AUTH_PASS=cambiar_esto
